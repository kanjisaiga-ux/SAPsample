projection;
strict ( 2 );
define behavior for ZC_SA_AP_REQUEST alias Request {
  use create;
  use update;
  use delete;
  use action Submit;
  use action Approve;
  use action Reject;
  use association _WorkItem { create; }
}
define behavior for ZC_SA_AP_WORK alias WorkItem {
  use update;
  use delete;
  use association _Request;
}
